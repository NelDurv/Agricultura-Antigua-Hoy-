  "conceptos_clave": [
    { "concepto": "Regla del 95/5", "descripcion": "95% de la planta es C-H-O gratis del aire y agua; solo 5% es NPK y minerales del suelo", "tags": ["nutrición", "fotosíntesis", "eficiencia"] },
    { "concepto": "ORP (Potencial Óxido-Reducción)", "descripcion": "Mide la carga de electrones/energía del suelo. Suelo sano: -100 a -300 mV", "tags": ["energía", "suelo", "medición"] },
    { "concepto": "rH", "descripcion": "Coeficiente que integra pH y ORP para una visión completa del estado energético del suelo", "tags": ["suelo", "energía", "medición"] },
    { "concepto": "IASS", "descripcion": "Índice de Sustentabilidad del Suelo. Valora física, química y biología. Óptimo: 30-40%", "tags": ["suelo", "sustentabilidad", "índice"] },
    { "concepto": "Biosilicificación", "descripcion": "Conversión biológica de H₄SiO₄ soluble en SiO₂ amorfo (fitolitos) en la planta", "tags": ["silicio", "defensa", "fitolitos"] },
    { "concepto": "Glomalina", "descripcion": "Glicoproteína producida por hongos micorrícicos que estabiliza agregados del suelo", "tags": ["suelo", "hongos", "estructura"] },
    { "concepto": "Quelatación biológica", "descripcion": "Encapsular minerales con ácidos orgánicos para evitar su fijación en el suelo y hacerlos asimilables", "tags": ["minerales", "nutrición", "bioinsumos"] },
    { "concepto": "CICE", "descripcion": "Capacidad de Intercambio Catiónico del suelo para retener e intercambiar cationes", "tags": ["suelo", "nutrición", "química"] },
    { "concepto": "Fotosíntesis", "descripcion": "Proceso que convierte CO₂ + H₂O + luz solar en glucosa y O₂. Sostiene la vida en la Tierra", "tags": ["planta", "energía", "azúcares"] },
    { "concepto": "ATP", "descripcion": "Moneda energética de la célula. 28 ATP con oxígeno vs. 2 ATP sin oxígeno", "tags": ["energía", "respiración", "metabolismo"] },
    { "concepto": "Fitorremediación", "descripcion": "Uso de plantas para absorber contaminantes del suelo", "tags": ["suelo", "contaminación", "limpieza"] },
    { "concepto": "Fertilizantes Híbridos de Lenta Liberación", "descripcion": "Combinación de minerales quelatados + matriz orgánica que libera nutrientes gradualmente", "tags": ["nutrición", "innovación", "eficiencia"] },
    { "concepto": "Estrategia I (Absorción de Hierro)", "descripcion": "Usada por la mayoría de plantas: acidifican rizósfera y reducen Fe³⁺ a Fe²⁺", "tags": ["hierro", "nutrición", "fisiología"] },
    { "concepto": "Estrategia II (Absorción de Hierro)", "descripcion": "Propia de gramíneas: liberan fitosideróforos que capturan Fe³⁺", "tags": ["hierro", "gramíneas", "fitosideróforos"] },
    { "concepto": "Milpa Maya", "descripcion": "Sistema de policultivo maíz-frijol-calabaza. Hasta 9 mazorcas/planta con nutrición mineral", "tags": ["ancestral", "Mesoamérica", "policultivo"] },
    { "concepto": "Terrazas Incas", "descripcion": "Sistemas andinos de laderas escalonadas con drenaje multicapa e inercia térmica de piedra", "tags": ["ancestral", "Andes", "hidrología"] },
    { "concepto": "Chinampas", "descripcion": "Islas artificiales flotantes aztecas en lagos someros. Hasta 5 cosechas/año", "tags": ["ancestral", "Mesoamérica", "humedales"] },
    { "concepto": "Subak", "descripcion": "Democracia hídrica de Bali con templos del agua y sincronización contra plagas", "tags": ["ancestral", "Indonesia", "riego"] },
    { "concepto": "Baray (Jemer)", "descripcion": "Megarreservorios elevados de Angkor. Ej: Baray Occidental de 8 × 2.2 km", "tags": ["ancestral", "Camboya", "hidráulica"] },
    { "concepto": "SRI", "descripcion": "Sistema de Intensificación del Arroz. 22.4 t/ha (récord), 5 kg semilla/ha, 50% menos agua", "tags": ["arroz", "innovación", "récord"] },
    { "concepto": "Suelo reducido vs. oxidado", "descripcion": "Reducido (-100 a -300 mV): rico en electrones y vida. Oxidado (+200 a +400 mV): consume energía", "tags": ["ORP", "energía", "salud del suelo"] },
    { "concepto": "Ley del Mínimo (Liebig)", "descripcion": "El nutriente menos disponible limita la producción, no el total aplicado", "tags": ["nutrición", "limitante", "eficiencia"] }
  ],

